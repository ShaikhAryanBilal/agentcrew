{
  "$schema": "https://opencode.ai/config.json",
  "skills": {
    "paths": ["~/.agents/skills"]
  },
  "command": {
    "agentcrew": {
      "description": "Load AgentCrew SDLC workflow skill and route the current request to an objective with role squad assignment",
      "template": "Load the sdlc skill and determine which objective applies to the user's request. Read .agentcrew/00-objectives.md to find the matching objective, then read .agentcrew/00-team.md for the invocation pattern. Load relevant role contracts and follow the objective file's procedure."
    }
  }
}
