{
  "$schema": "https://opencode.ai/config.json",
  "skills": { "paths": ["~/.agents/skills"] },
  "command": {
    "CrewMarkdown": {
      "description": "Load CrewMarkdown skill, route request to objective, assign squad",
      "template": "Load CrewMarkdown skill. Read .crewmarkdown/00-objectives.md → match request → read objective → read 00-team.md → load role contracts → execute → log → update state."
    }
  }
}
