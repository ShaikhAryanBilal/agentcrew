{
  "$schema": "https://opencode.ai/config.json",
  "skills": { "paths": ["~/.agents/skills"] },
  "command": {
    "agentcrew": {
      "description": "Load SDLC skill, route request to objective, assign squad",
      "template": "Load sdlc skill. Read .agentcrew/00-objectives.md → match request → read objective → read 00-team.md → load role contracts → execute → log → update state."
    }
  }
}
